{{- if .kiro }}
# Kiro CLI pre block. Keep at the top of this file.
[[ -f "${HOME}/.local/share/kiro-cli/shell/zshrc.pre.zsh" ]] && builtin source "${HOME}/.local/share/kiro-cli/shell/zshrc.pre.zsh"
{{- end }}

#
# Executes commands at the start of an interactive session.
#
# Authors:
#   Sorin Ionescu <sorin.ionescu@gmail.com>
#

# Always show hostname in Pure prompt
export PROMPT_PURE_SSH_CONNECTION="force"

# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Customize to your needs...
# NOTE: Environment variables and PATH live in ~/.zprofile (single source of
# truth). Keep only interactive-only settings (prompt, aliases, shell
# integrations) here.
{{- if .wsl }}

# WSL
alias cursor-setup="$HOME/cursor-setup-wizard/cursor_setup.sh"
{{- end }}
{{- if .kiro }}

# Kiro CLI post block. Keep at the bottom of this file.
[[ -f "${HOME}/.local/share/kiro-cli/shell/zshrc.post.zsh" ]] && builtin source "${HOME}/.local/share/kiro-cli/shell/zshrc.post.zsh"
{{- end }}
