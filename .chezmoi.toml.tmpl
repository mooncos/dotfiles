{{- $is_mac := eq .chezmoi.os "darwin" -}}
{{- $is_wsl := false -}}
{{- if not $is_mac -}}
{{-   $is_wsl = (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}
{{- end -}}

[data]
    is_mac = {{ $is_mac }}
    wsl = {{ $is_wsl }}
    kiro = {{ promptBoolOnce . "kiro" "Install Kiro CLI hooks" | not | not }}
    golang = {{ promptBoolOnce . "golang" "Install Go PATH" | not | not }}
    tmux = {{ promptBoolOnce . "tmux" "Install tmux config" | not | not }}
    prezto = {{ promptBoolOnce . "prezto" "Install Prezto (zsh framework)" | not | not }}
    brewfile = {{ promptBoolOnce . "brewfile" "Manage Homebrew packages via Brewfile" | not | not }}
